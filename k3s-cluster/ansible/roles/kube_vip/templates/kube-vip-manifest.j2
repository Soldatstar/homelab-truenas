apiVersion: v1
kind: Pod
metadata:
  name: kube-vip-{{ inventory_hostname }}
  namespace: kube-system
spec:
  containers:
  - name: kube-vip
    image: ghcr.io/kube-vip/kube-vip:v0.8.0
    args:
      - manager
    env:
      - name: vip_arp
        value: "true"
      - name: vip_interface
        value: "{{ kube_vip_interface }}"
      - name: vip_address
        value: "{{ kube_vip_address }}"
      - name: vip_leaderelection
        value: "true"
      - name: vip_leaseduration
        value: "15"
      - name: vip_renewdeadline
        value: "10"
      - name: vip_retryperiod
        value: "2"
      - name: cp_enable
        value: "true"
      - name: cp_port
        value: "6443"
    securityContext:
      capabilities:
        add:
          - NET_ADMIN
          - NET_RAW
          - SYS_TIME
    volumeMounts:
      - mountPath: /etc/kubernetes/admin.conf
        name: kubeconfig
  hostNetwork: true
  hostAliases:
    - ip: 127.0.0.1
      hostnames:
        - kubernetes
  volumes:
    - name: kubeconfig
      hostPath:
        path: /etc/rancher/k3s/k3s.yaml
  priorityClassName: system-node-critical
  tolerations:
    - key: node-role.kubernetes.io/control-plane
      operator: Exists
      effect: NoSchedule
    - key: node-role.kubernetes.io/master
      operator: Exists
      effect: NoSchedule
